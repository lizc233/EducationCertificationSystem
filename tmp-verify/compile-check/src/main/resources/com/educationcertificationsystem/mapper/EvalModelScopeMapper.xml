<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educationcertificationsystem.eval.mapper.EvalModelScopeMapper">

    <resultMap id="BaseResultMap" type="com.educationcertificationsystem.model.entity.EvalModelScope">
            <id property="id" column="id" />
            <result property="modelId" column="model_id" />
            <result property="scopeType" column="scope_type" />
            <result property="scopeId" column="scope_id" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
            <result property="isDeleted" column="is_deleted" />
            <result property="remark" column="remark" />
    </resultMap>

    <sql id="Base_Column_List">
        id,model_id,scope_type,scope_id,created_at,updated_at,
        is_deleted,remark
    </sql>

    <select id="selectActiveByModelId" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from eval_model_scope
        where model_id = #{modelId}
          and is_deleted = 0
        order by id asc
    </select>

    <delete id="deleteByModelId">
        delete from eval_model_scope
        where model_id = #{modelId}
    </delete>
</mapper>
