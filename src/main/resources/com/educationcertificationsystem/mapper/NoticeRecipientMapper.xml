<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educationcertificationsystem.notice.mapper.NoticeRecipientMapper">

    <resultMap id="BaseResultMap" type="com.educationcertificationsystem.model.entity.NoticeRecipient">
            <id property="id" column="id" />
            <result property="noticeId" column="notice_id" />
            <result property="recipientUserId" column="recipient_user_id" />
            <result property="readStatus" column="read_status" />
            <result property="readAt" column="read_at" />
            <result property="deletedFlag" column="deleted_flag" />
            <result property="createdAt" column="created_at" />
            <result property="updatedAt" column="updated_at" />
            <result property="isDeleted" column="is_deleted" />
            <result property="remark" column="remark" />
    </resultMap>

    <sql id="Base_Column_List">
        id,notice_id,recipient_user_id,read_status,read_at,deleted_flag,
        created_at,updated_at,is_deleted,remark
    </sql>

    <sql id="NoticeRecipient_Where">
        where is_deleted = 0
          and deleted_flag = 0
        <if test="noticeId != null">
            and notice_id = #{noticeId}
        </if>
        <if test="recipientUserId != null">
            and recipient_user_id = #{recipientUserId}
        </if>
        <if test="readStatus != null">
            and read_status = #{readStatus}
        </if>
    </sql>

    <select id="selectActiveById" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from notice_recipient
        where id = #{id}
          and is_deleted = 0
          and deleted_flag = 0
        limit 1
    </select>

    <select id="selectByNoticeIdAndRecipientUserId" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from notice_recipient
        where notice_id = #{noticeId}
          and recipient_user_id = #{recipientUserId}
        limit 1
    </select>

    <select id="countByCondition" resultType="long">
        select count(1)
        from notice_recipient
        <include refid="NoticeRecipient_Where"/>
    </select>

    <select id="countUnread" resultType="long">
        select count(1)
        from notice_recipient
        where is_deleted = 0
          and deleted_flag = 0
          and recipient_user_id = #{recipientUserId}
          and read_status = 0
    </select>

    <select id="selectByCondition" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from notice_recipient
        <include refid="NoticeRecipient_Where"/>
        order by id desc
        limit #{offset}, #{size}
    </select>

    <insert id="batchInsertIgnore">
        insert ignore into notice_recipient (
            notice_id,
            recipient_user_id,
            read_status,
            deleted_flag,
            is_deleted,
            remark
        )
        values
        <foreach collection="list" item="item" separator=",">
            (
                #{item.noticeId},
                #{item.recipientUserId},
                #{item.readStatus},
                #{item.deletedFlag},
                #{item.isDeleted},
                #{item.remark}
            )
        </foreach>
    </insert>
</mapper>
